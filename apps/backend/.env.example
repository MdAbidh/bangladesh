# ============================================
# BACKEND (NestJS) - Environment Variables
# Copy to .env for local development
# ============================================

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ah_learning

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional locally - comment out if not installed)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

# Firebase Admin (from Firebase Console > Service Accounts > Generate new private key)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_STORAGE_BUCKET=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ahlearning.com
SMTP_FROM_NAME=A.H Learning

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CACHE_TTL=300

# Monitoring (optional)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Logging
LOG_LEVEL=info
