# ============================================
# A.H Learning App - Environment Variables
# Copy to .env for local development
# ============================================

# ============================================
# FRONTEND (Next.js)
# ============================================
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Firebase Client (Frontend - from Firebase Console)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# ============================================
# BACKEND (NestJS)
# ============================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_PREFIX=api/v1

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ah_learning

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_REFRESH_SECRET=change-this-to-another-random-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Redis (optional - app works without it)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Firebase Admin (Backend - from Firebase Console > Service Accounts)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_STORAGE_BUCKET=

# SMTP (Email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ahlearning.com
SMTP_FROM_NAME=A.H Learning

# CORS
CORS_ORIGINS=http://localhost:3000

# Rate Limiting
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
CACHE_TTL=300

# Monitoring
SENTRY_DSN=

# Logging
LOG_LEVEL=info
